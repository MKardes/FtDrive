# FtDrive configuration — copy to .env and fill in. NEVER commit a real .env.
# All values are validated at startup (fail-fast).

# Root directory for per-user file storage (blobs + thumbnails + tmp).
DATA_ROOT=./data

# SQLite metadata database file.
DATABASE_PATH=./data/ftdrive.db

# Cookie signing secret — REQUIRED, must be >= 32 characters.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Trust X-Forwarded-* headers from a reverse proxy (set true in production behind TLS).
TRUST_PROXY=false

# Per-file upload limit in bytes (default 5 GiB).
MAX_UPLOAD_BYTES=5368709120

# Days a trashed item is retained before the sweep purges it permanently.
TRASH_RETENTION_DAYS=30

# Session lifetime in days.
SESSION_TTL_DAYS=30

# Server bind config.
HOST=0.0.0.0
PORT=3000

# NODE_ENV controls Secure cookie enforcement (production => Secure required).
NODE_ENV=development

# Optional one-time owner bootstrap (used by `npm run create-owner` when flags omitted).
# OWNER_BOOTSTRAP_USERNAME=owner
# OWNER_BOOTSTRAP_PASSWORD=
