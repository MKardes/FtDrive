# FtDrive configuration — copy to .env and fill in. NEVER commit a real .env.
# All values are validated at startup (fail-fast).

# Root directory for per-user file storage (blobs + thumbnails + tmp).
DATA_ROOT=./data

# SQLite metadata database file.
DATABASE_PATH=./data/ftdrive.db

# Cookie signing secret — REQUIRED, must be >= 32 characters.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Trust X-Forwarded-* headers from a reverse proxy (set true in production behind TLS).
TRUST_PROXY=false

# Per-file upload limit in bytes (default 5 GiB).
MAX_UPLOAD_BYTES=5368709120

# Days a trashed item is retained before the sweep purges it permanently.
TRASH_RETENTION_DAYS=30

# Session lifetime in days.
SESSION_TTL_DAYS=30

# Server bind config.
HOST=0.0.0.0
PORT=3000

# NODE_ENV controls Secure cookie enforcement (production => Secure required).
NODE_ENV=development

# Optional one-time owner bootstrap (used by `npm run create-owner` when flags omitted).
# OWNER_BOOTSTRAP_USERNAME=owner
# OWNER_BOOTSTRAP_PASSWORD=

# --- Download-from-web (002-url-video-download) ---

# Master on/off for the feature. When false (or yt-dlp is missing), download
# endpoints report 503 and the rest of FtDrive is unaffected.
DOWNLOADS_ENABLED=true

# Path to the yt-dlp binary (or just the name if it's on PATH).
YT_DLP_PATH=yt-dlp

# Simultaneous downloads per user; the rest queue.
DOWNLOAD_MAX_CONCURRENCY_PER_USER=5

# Absolute per-download size ceiling in bytes (default 20 GB).
DOWNLOAD_MAX_BYTES=21474836480

# Per-download wall-clock cap in milliseconds (default 6 h).
DOWNLOAD_MAX_DURATION_MS=21600000

# Bound on examination (incl. headless-browser fallback), in milliseconds.
DOWNLOAD_EXAMINE_TIMEOUT_MS=30000

# Per-user total storage limit in bytes. 0 = unlimited.
USER_STORAGE_QUOTA_BYTES=0

# Allow LAN/private download targets. Leave false unless you deliberately want
# to fetch from your own network (SSRF guard opt-out).
DOWNLOAD_ALLOW_PRIVATE_ADDRESSES=false
