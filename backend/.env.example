# FtDrive backend (API app) configuration — copy to `backend/.env` for local dev.
# `npm run dev:backend` and `npm run create-owner` load this file automatically.

# Where user files + the SQLite database live (relative to the backend/ dir).
DATA_ROOT=./data
DATABASE_PATH=./data/ftdrive.db

# REQUIRED: signs session cookies. Must be >= 32 chars.
# Generate one: openssl rand -base64 36
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Trust X-Forwarded-* headers from a reverse proxy (set true in production behind TLS).
TRUST_PROXY=false

# Per-file upload limit in bytes (default 5 GiB).
MAX_UPLOAD_BYTES=5368709120

# Days a trashed item is retained before the sweep purges it permanently.
TRASH_RETENTION_DAYS=30

# Session lifetime in days.
SESSION_TTL_DAYS=30

# Server bind config.
HOST=0.0.0.0
PORT=3000

# development => API-only app (frontend runs separately via Vite).
# production  => single deployable (also serves the built SPA) + Secure cookies.
NODE_ENV=development

# Optional one-time owner bootstrap (used by `npm run create-owner` when flags omitted).
# Password must be at least 10 characters.
OWNER_BOOTSTRAP_USERNAME=admin
OWNER_BOOTSTRAP_PASSWORD=admin-password
