{
  "name": "@ftdrive/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "create-owner": "tsx src/cli/create-owner.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.0.4",
    "argon2": "^0.43.0",
    "better-sqlite3": "^12.2.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.4.0",
    "pino": "^9.7.0",
    "sharp": "^0.34.2",
    "ulidx": "^2.4.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
