{
  "name": "ftdrive",
  "version": "0.1.0",
  "private": true,
  "description": "FtDrive — self-hosted, Google Drive–like personal cloud (web application).",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "backend",
    "frontend",
    "e2e"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend && npm run build --workspace backend",
    "start": "npm run start --workspace backend",
    "test": "npm run test --workspace backend && npm run test --workspace frontend",
    "test:backend": "npm run test --workspace backend",
    "test:frontend": "npm run test --workspace frontend",
    "test:e2e": "npm run test --workspace e2e",
    "typecheck": "npm run typecheck --workspace backend && npm run typecheck --workspace frontend",
    "db:migrate": "npm run db:migrate --workspace backend",
    "create-owner": "npm run create-owner --workspace backend",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
